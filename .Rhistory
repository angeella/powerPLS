#' @title PLS
#' @description Performs PLS two class
#' @usage PLSc(X, Y, A, scaling, post.transformation = TRUE)
#' @param X data matrix where columns represent the \eqn{p} classes and rows the \eqn{n} observations.
#' @param Y data matrix where columns represent the \eqn{k} variables and rows the \eqn{n} observations.
#' @param A number of components
#' @author Angela Andreella
#' @return Returns a list with the following objects:
#' - \code{W}: matrix of weigths
#' - \code{X.loading}: matrix of X loading
#' - \code{Y.loading}: matirx of Y loading
#' - \code{T_score}: matrix of scores
#' - \code{Y.fitted}: fitted Y matrix
#' - \code{B}: Matrix regression coefficients
#' - \code{M}: number of orthogonal components if post transformation is applied.
PLSc <- function(X, Y, A, scaling, post.transformation = TRUE){
if(dim(X)[1] != dim(Y)[1]){stop("X and Y must have the same number of observations!")}
#TODO check arguments scaling
if(scaling == "auto-scaling"){
X <- X - apply(X, 2, mean)
X <- sweep(X, 2, as.matrix(apply(X, 2, var)), "/")
}
if(scaling == "pareto-scaling"){
X <- X - apply(X, 2, mean)
X <- sweep(X, 2, as.matrix(apply(X, 2, sd)), "/")
}
if(scaling == "mean-centering"){
X <- X - apply(X, 2, mean)
}
#check if Y must be transformed
if(sum(Y[1,]== 1)==1){
P <- matrix(as.numeric(clrInv(Y)), ncol = ncol(Y))
}
n <- nrow(X)
out <- computeWT(X = X, Y = P, A = A, scaling = scaling)
W <- out$W
T.score <- out$T.score
R <- out$R
if(post.transformation){
out <- ptPLSc(X, P, W)
Wtilde <- out$Wtilde
G <- out$G
M <- out$M
#apply G to weight matrix
Wtilde <- W %*% G #nX times ncomp
N <- dim(X)[1]
E <- r <- Q <- list()
E[[1]] <- X
T.score <- IDA(X = X, Y = Y, W = Wtilde)
}else{
M <- NULL
}
#Compute loadings matrix
X.loading = t(X) %*% T.score %*% solve(t(T.score) %*% T.score)
Y.loading = t(Y) %*% T.score %*% solve(t(T.score) %*% T.score)
#matrix coefficients
Wstar = W %*% solve(t(X.loading) %*%W)
B = Wstar %*% t(Y.loading)
Y.fitted <- fitY(X, B)
return(list(X.loading = X.loading,
Y.loading = Y.loading,
B = B,
M = M,
T.score = T.score,
Y.fitted = Y.fitted))
}
outPLS <- PLSc(X = X, Y = Y, A = A,
scaling = scaling,
post.transformation = post.transformation)
out <- computePower(X, Y, A = 3, scaling = FALSE,
post.transformation = TRUE, seed = 123, n = nrow(X),
Nsim = 100, nperm = 1000, alpha = 0.05)
#' @title power computations
#' @description Performs randomization test based on eigenvalues
#' @usage computePower(X, Y, A, nperm, A, scaling, post.transformation)
#' @param X data matrix where columns represent the \eqn{p} classes and rows the \eqn{n} observations.
#' @param Y data matrix where columns represent the \eqn{k} variables and rows the \eqn{n} observations.
#' @param nperm number of permutations
#' @param A number of components
#' @param post.transformation TRUE if you want to apply post transformation.
#' @author Angela Andreella
#' @return Returns the corresponding pvalues
computePower <- function(X, Y, A, scaling,
post.transformation, seed, n = nrow(X),
Nsim = 100, nperm = 100, alpha = 0.05){
#Build the reference model PLS2c
outPLS <- PLSc(X = X, Y = Y, A = A,
scaling = scaling,
post.transformation = post.transformation)
pw <- 0
for(i in seq(Nsim)){
#Model the distribution of the X-data
outsim <- sim_XY(outPLS, n = n, seed = seed,
post.transformation = post.transformation, A = A)
#Model the distribution of the Y-data
Xsim <- outsim$X_H1
Ysim <- outsim$Y_H1
pv <- eigenTest(X = Xsim, Y = Ysim, A = A, nperm = nperm,
scaling = scaling)
if(pv[A] <= alpha){pw <- pw + 1}
}
pw <- sum(pw)/Nsim
return(pw)
}
